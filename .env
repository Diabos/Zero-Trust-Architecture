# =============================================================
# AZTIH Environment Configuration
# Copy this file to .env and fill in your actual values
# =============================================================

# n8n Configuration
N8N_WEBHOOK_URL=http://your-n8n-instance:5678/webhook/aztih-hardening
N8N_API_KEY=your_n8n_api_key_here

# OpenClaw AI Configuration
OPENCLAW_ENDPOINT=http://openclaw-instance:8000/api/v1/analyze
OPENCLAW_API_KEY=your_openclaw_api_key_here

# Slack Integration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Target Server SSH Configuration
TARGET_SERVER_HOST=192.168.241.128
TARGET_SERVER_USER=kali
TARGET_SERVER_PASSWORD=kali
TARGET_SERVER_SSH_KEY=
TARGET_SERVER_PORT=22
TARGET_SERVER_NAME=Kali Test Server
TARGET_SERVER_USE_SUDO=true

# Hardening Script Location (on target)
HARDENING_SCRIPT_PATH=/tmp/zero_trust_harden.sh

# Audit Log Locations (on target)
AUTH_LOG_PATH=/var/log/auth.log
AUDIT_LOG_PATH=/var/log/audit/audit.log

# Dashboard Configuration
PORT=3000
DASHBOARD_PORT=3000
DASHBOARD_API_BASE_URL=http://localhost:5678

# Logging
LOG_LEVEL=info
